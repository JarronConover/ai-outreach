# ─────────────────────────────────────────────────────────────────────────────
# Fellowship AI – Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────


# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL and service-role key from Supabase dashboard:
#   Settings → API → Project URL / API Keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here


# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Supabase public keys for the React app — safe to expose in the browser.
# anon key from: Settings → API → Project API Keys → anon / public
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here


# ── Google OAuth credentials ──────────────────────────────────────────────────
# Download credentials.json from Google Cloud Console:
#   APIs & Services → Credentials → OAuth 2.0 Client IDs → Download JSON
# Enable these APIs in your project:
#   • Gmail API
#   • Google Calendar API
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.pickle


# ── Google AI (Gemini) ────────────────────────────────────────────────────────
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here


# ── Tavily (web search) ───────────────────────────────────────────────────────
# Get your API key from: https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here


# ── Sender identity (outreach-agent) ─────────────────────────────────────────
SENDER_EMAIL=you@yourcompany.com
SENDER_NAME=Your Name
COMPANY_NAME=Your Company
# Optional: included as a calendar attendee on every demo event (e.g. a team inbox)
BCC_EMAIL=bcc@yourcompany.com


# ── Calendar settings (outreach-agent) ───────────────────────────────────────
CALENDAR_TIMEZONE=America/Denver
DEMO_DURATION_MINUTES=30
FOLLOWUP_DURATION_MINUTES=30

# Set to "false" to disable Google Meet links on calendar events
GOOGLE_MEET=true


# ── Outreach cadence (outreach-agent) ────────────────────────────────────────
# Days since last contact before sending a follow-up to mid-pipeline contacts
FOLLOWUP_DAYS=7

# Days since last contact before sending a check-in to existing clients
CLIENT_CHECKIN_DAYS=30


# ── API poller settings ───────────────────────────────────────────────────────
# How often (seconds) the API polls Supabase for new uncontacted people
POLL_INTERVAL=60

# How often (hours) the API fires a scheduled outreach run for follow-ups
OUTREACH_INTERVAL_HOURS=24
